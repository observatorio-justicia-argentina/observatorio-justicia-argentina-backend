# ── Entorno ──────────────────────────────────────────────────────────────────
# "production" activa cookies secure + sameSite=none, CORS estricto y logs de prod
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Cambiá esto por un valor aleatorio largo y seguro en producción
JWT_SECRET=OJA_DEV_SECRET_CHANGE_IN_PRODUCTION

# ── Puerto ────────────────────────────────────────────────────────────────────
# Render inyecta PORT automáticamente; localmente se usa 3600
# PORT=3600

# ── CORS — orígenes adicionales del frontend ──────────────────────────────────
# Lista separada por comas; el origen de Vercel ya está hardcodeado en main.ts
# FRONTEND_URLS=https://mi-otro-dominio.com,https://staging.miapp.com
